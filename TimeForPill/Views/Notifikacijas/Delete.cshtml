@model Notifikacija

@{
    ViewData["Title"] = "Brisanje notifikacije";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Podsjetnici</p>
        <h1>Brisanje notifikacije</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Nazad</a>
</div>

<div class="details-shell">
    <p class="lead mb-4">Da li zelite obrisati notifikaciju <strong>@Model.Naziv</strong>?</p>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Obrisi</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Odustani</a>
    </form>
</div>
