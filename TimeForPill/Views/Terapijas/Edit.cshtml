@model Terapija

@{
    ViewData["Title"] = "Uredi terapiju";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Plan terapije</p>
        <h1>Uredi terapiju</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Nazad</a>
</div>

<div class="form-shell">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="mb-3"></div>
        <div class="form-grid">
            <div>
                <label asp-for="Naziv" class="form-label"></label>
                <input asp-for="Naziv" class="form-control" />
                <span asp-validation-for="Naziv"></span>
            </div>
            <div>
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<StatusTerapije>()" class="form-select"></select>
                <span asp-validation-for="Status"></span>
            </div>
            <div>
                <label asp-for="Pocetak" class="form-label"></label>
                <input asp-for="Pocetak" class="form-control" />
                <span asp-validation-for="Pocetak"></span>
            </div>
            <div>
                <label asp-for="Kraj" class="form-label"></label>
                <input asp-for="Kraj" class="form-control" />
                <span asp-validation-for="Kraj"></span>
            </div>
            <div>
                <label asp-for="DnevnaDoza" class="form-label"></label>
                <input asp-for="DnevnaDoza" class="form-control" />
                <span asp-validation-for="DnevnaDoza"></span>
            </div>
            <div>
                <label asp-for="LijekId" class="form-label"></label>
                <select asp-for="LijekId" asp-items="ViewBag.LijekId" class="form-select">
                    <option value="">Odaberite lijek</option>
                </select>
                <span asp-validation-for="LijekId"></span>
            </div>
            <div class="span-2">
                <label asp-for="PacijentId" class="form-label"></label>
                <select asp-for="PacijentId" asp-items="ViewBag.PacijentId" class="form-select">
                    <option value="">Odaberite pacijenta</option>
                </select>
                <span asp-validation-for="PacijentId"></span>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Sacuvaj izmjene</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
