@model Terapija

@{
    ViewData["Title"] = "Detalji terapije";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Plan terapije</p>
        <h1>@Model.Naziv</h1>
    </div>
    <div class="actions">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Uredi</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Nazad</a>
    </div>
</div>

<div class="details-shell">
    <dl class="row mb-0">
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>
        <dt class="col-sm-3">Pocetak</dt>
        <dd class="col-sm-9">@Model.Pocetak.ToString("dd.MM.yyyy")</dd>
        <dt class="col-sm-3">Kraj</dt>
        <dd class="col-sm-9">@Model.Kraj.ToString("dd.MM.yyyy")</dd>
        <dt class="col-sm-3">Dnevna doza</dt>
        <dd class="col-sm-9">@Model.DnevnaDoza</dd>
        <dt class="col-sm-3">Lijek</dt>
        <dd class="col-sm-9">@(Model.Lijek?.Naziv ?? "Nije odabran")</dd>
        <dt class="col-sm-3">Pacijent</dt>
        <dd class="col-sm-9">@(Model.Pacijent == null ? "Nije odabran" : Model.Pacijent.Ime + " " + Model.Pacijent.Prezime)</dd>
    </dl>
</div>
