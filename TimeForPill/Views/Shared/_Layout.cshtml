@inject Microsoft.AspNetCore.Identity.UserManager<TimeForPill.Models.ApplicationUser> UserManager
@{
    var title = ViewData["Title"] ?? "TimeForPill";
    var isAuthPage = ViewData["AuthPage"] is bool authPage && authPage;
    var currentUser = User.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;
}

<!DOCTYPE html>
<html lang="bs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - TimeForPill</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (!isAuthPage)
    {
        <header class="app-topbar">
            <nav class="navbar navbar-expand-lg">
                <div class="container-fluid px-4">
                    <a class="navbar-brand brand-lockup" asp-controller="Home" asp-action="Index">
                        <span class="brand-mark">+</span>
                        <span>TimeForPill</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Navigacija">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav ms-auto gap-lg-1 align-items-lg-center">
                            @if (currentUser is Pacijent)
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Pacijent" asp-action="Home">Home</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Pacijent" asp-action="MojiLijekovi">Moji lijekovi</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Pacijent" asp-action="ObnovaTerapije">Obnova terapije</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Pacijent" asp-action="Raspored">Raspored</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Pacijent" asp-action="Historija">Historija</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Pacijent" asp-action="Profil">Moj profil</a></li>
                            }
                            else if (currentUser is Ljekar)
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Ljekar" asp-action="Home">Home</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Ljekar" asp-action="Zahtjevi">Zahtjevi</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Ljekar" asp-action="Profil">Moj profil</a></li>
                            }
                            else if (currentUser is Administrator)
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Home">Home</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="PregledPacijenata">Pregled pacijenata</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="PregledLjekara">Pregled ljekara</a></li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Registracija</a></li>
                            }

                            @if (currentUser != null)
                            {
                                <li class="nav-item nav-user">
                                    @currentUser.Ime @currentUser.Prezime
                                </li>
                                <li class="nav-item">
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        <button type="submit" class="btn btn-outline-secondary btn-sm">Odjava</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    <main class="@(isAuthPage ? "auth-shell" : "app-shell")">
        <div class="container-fluid px-4 py-4 py-lg-5">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success app-alert" role="alert">
                    @TempData["Success"]
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
