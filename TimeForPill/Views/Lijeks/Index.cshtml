@model IEnumerable<Lijek>

@{
    ViewData["Title"] = "Lijekovi";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Katalog</p>
        <h1>Lijekovi</h1>
    </div>
    <a class="btn btn-primary" asp-action="Create">Dodaj lijek</a>
</div>

<div class="table-shell table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Slika</th>
                <th>Naziv</th>
                <th>Kategorija</th>
                <th class="text-end">Akcije</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrWhiteSpace(item.Slika))
                    {
                        <img class="pill-img" src="@item.Slika" alt="@item.Naziv" />
                    }
                    else
                    {
                        <span class="text-muted">Nema slike</span>
                    }
                </td>
                <td><strong>@item.Naziv</strong></td>
                <td>@item.Kategorija</td>
                <td>
                    <div class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Uredi</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Detalji</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Obrisi</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
