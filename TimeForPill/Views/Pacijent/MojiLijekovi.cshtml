@model IReadOnlyList<MedicineListItemViewModel>
@{
    ViewData["Title"] = "Moji lijekovi";
}

<section class="page-headline">
    <div>
        <p class="eyebrow">Pacijent</p>
        <h1>Moji lijekovi</h1>
    </div>
    <a class="btn btn-primary" asp-action="LijekForma">Dodaj terapiju</a>
</section>

@if (!Model.Any())
{
    <section class="empty-state">
        <h2>Jos nema sacuvanih terapija</h2>
        <p class="muted-text">Dodajte prvu terapiju da bi se pojavila u rasporedu i historiji uzimanja.</p>
        <a class="btn btn-primary" asp-action="LijekForma">Dodaj terapiju</a>
    </section>
}
else
{
    <section class="medicine-grid">
        @foreach (var lijek in Model)
        {
            <article class="medicine-card">
                <div class="medicine-image">
                    @if (!string.IsNullOrWhiteSpace(lijek.Slika))
                    {
                        <img src="@lijek.Slika" alt="@lijek.Naziv" />
                    }
                    else
                    {
                        <img src="~/images/generic-medicine.jpg" asp-append-version="true" alt="Genericki lijek" />
                    }
                </div>
                <div class="medicine-body">
                    <div class="section-row">
                        <div>
                            <small>@lijek.Kategorija</small>
                            <h2>@lijek.Naziv</h2>
                        </div>
                        <span class="status-badge status-@lijek.Status.ToString().ToLower()">@lijek.Status</span>
                    </div>
                    <dl class="info-list">
                        <div>
                            <dt>Doziranje</dt>
                            <dd>@lijek.UkupanBrojDoza doza, svakih @lijek.IntervalSati h</dd>
                        </div>
                        <div>
                            <dt>Trajanje</dt>
                            <dd>@lijek.Pocetak.ToString("dd.MM.yyyy") - @lijek.Kraj.ToString("dd.MM.yyyy")</dd>
                        </div>
                        <div>
                            <dt>Sljedeca doza</dt>
                            <dd>@lijek.SljedecaDoza</dd>
                        </div>
                        <div>
                            <dt>Evidencija</dt>
                            <dd>@lijek.UzeteDoze uzeto, @lijek.PropusteneDoze propusteno, @lijek.CekajuceDoze ceka</dd>
                        </div>
                    </dl>
                    <div class="button-row">
                        <a class="btn btn-outline-secondary" asp-action="LijekForma" asp-route-id="@lijek.TerapijaId">Azuriraj terapiju</a>
                        <a class="btn btn-outline-secondary" asp-action="PrijaviNuspojavu" asp-route-id="@lijek.TerapijaId">Nuspojave</a>
                        <form asp-action="ObrisiLijek" method="post">
                            <input type="hidden" name="id" value="@lijek.TerapijaId" />
                            <button type="submit" class="btn btn-outline-danger">Obrisi terapiju</button>
                        </form>
                    </div>
                </div>
            </article>
        }
    </section>
}
