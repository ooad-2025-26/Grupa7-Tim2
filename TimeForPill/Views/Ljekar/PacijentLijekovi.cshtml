@model DoctorPatientMedicationViewModel
@{
    ViewData["Title"] = "Lijekovi pacijenta";
}

<section class="page-headline">
    <div>
        <p class="eyebrow">Pacijent</p>
        <h1>@Model.Pacijent</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-action="MojiPacijenti">Nazad</a>
</section>

@if (!Model.Lijekovi.Any())
{
    <section class="empty-state">
        <h2>Nema aktivnih lijekova</h2>
        <p class="muted-text">Pacijent trenutno nema pending doza u terapiji.</p>
    </section>
}
else
{
    <section class="medicine-grid">
        @foreach (var lijek in Model.Lijekovi)
        {
            <article class="medicine-card">
                <div class="medicine-body">
                    <div class="section-row">
                        <div>
                            <small>@lijek.Kategorija</small>
                            <h2>@lijek.Naziv</h2>
                        </div>
                    </div>
                    <dl class="info-list">
                        <div>
                            <dt>Pravilo</dt>
                            <dd>@lijek.UkupanBrojDoza doza, svakih @lijek.IntervalSati h</dd>
                        </div>
                        <div>
                            <dt>Sljedeca doza</dt>
                            <dd>@lijek.SljedecaDoza</dd>
                        </div>
                        <div>
                            <dt>Period</dt>
                            <dd>@lijek.Period</dd>
                        </div>
                        <div>
                            <dt>Evidencija</dt>
                            <dd>@lijek.UzeteDoze uzeto, @lijek.PropusteneDoze propusteno, @lijek.CekajuceDoze ceka</dd>
                        </div>
                    </dl>
                </div>
            </article>
        }
    </section>
}
