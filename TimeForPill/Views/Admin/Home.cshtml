@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Administrator Pocetna";
}

<section class="page-headline">
    <div>
        <p class="eyebrow">Administrator</p>
        <h1>Dobro dosli, @Model.Ime</h1>
    </div>
</section>

<section class="stat-grid">
    <article class="stat-card patient-stat-blue">
        <small>Broj pacijenata</small>
        <strong>@Model.BrojPacijenata</strong>
    </article>
    <article class="stat-card patient-stat-green">
        <small>Broj ljekara</small>
        <strong>@Model.BrojLjekara</strong>
    </article>
    <article class="stat-card patient-stat-red">
        <small>Broj izvrsenih akcija</small>
        <strong>@Model.BrojIzvrsenihAkcija</strong>
    </article>
</section>

<section class="dashboard-two mt-4">
    <article class="app-card admin-home-card admin-management-card">
        <div class="section-row">
            <div>
                <p class="eyebrow">Korisnici</p>
                <h2>Upravljanje nalozima</h2>
            </div>
            <div class="request-bell" aria-label="Broj zahtjeva za potvrdu naloga">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M10 21h4"></path>
                    <path d="M18 8a6 6 0 0 0-12 0c0 7-3 8-3 8h18s-3-1-3-8"></path>
                </svg>
                <span>@Model.BrojZahtjevaZaPotvrdu</span>
            </div>
        </div>
        <div class="request-home-layout">
            @if (Model.ZadnjiZahtjevZaPotvrdu == null)
            {
                <div class="request-summary">
                    <p class="muted-text mb-0">Nema zahtjeva za potvrdu naloga.</p>
                </div>
            }
            else
            {
                <a class="request-summary request-summary-link"
                   asp-action="ZahtjevNalogaDetalji"
                   asp-route-id="@Model.ZadnjiZahtjevZaPotvrdu.Id">
                    <small>Zadnji zahtjev za potvrdu naloga</small>
                    <strong>@Model.ZadnjiZahtjevZaPotvrdu.ImePrezime</strong>
                    <span>@Model.ZadnjiZahtjevZaPotvrdu.Uloga - @Model.ZadnjiZahtjevZaPotvrdu.Specijalizacija</span>
                    <span>@Model.ZadnjiZahtjevZaPotvrdu.Email</span>
                </a>
            }
            <a class="btn btn-primary request-main-button" asp-action="ZahtjeviNaloga">Zahtjevi</a>
        </div>
    </article>

    <article class="app-card admin-home-card admin-activity-card">
        <div class="section-row">
            <div>
                <p class="eyebrow">Zadnje akcije</p>
                <h2>Aktivnosti</h2>
            </div>
        </div>
        @if (!Model.ZadnjeAkcije.Any())
        {
            <p class="muted-text mb-0">Nema evidentiranih akcija.</p>
        }
        else
        {
            <div class="action-list admin-action-list">
                @foreach (var akcija in Model.ZadnjeAkcije)
                {
                    <span>@akcija</span>
                }
            </div>
        }
    </article>
</section>
