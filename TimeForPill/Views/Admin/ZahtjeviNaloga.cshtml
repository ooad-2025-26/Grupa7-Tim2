@model IReadOnlyList<AccountApprovalRequestViewModel>

@{
    ViewData["Title"] = "Upravljanje nalozima";
}

<section class="page-headline">
    <div>
        <p class="eyebrow">Administrator</p>
        <h1>Upravljanje nalozima</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Home">Nazad</a>
</section>

<section class="table-shell">
    <div class="admin-patient-toolbar" aria-label="Filteri naloga">
        <label class="admin-patient-control">
            <span class="admin-patient-control-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>
            </span>
            <input id="accountRequestSearch" type="search" placeholder="Pretrazi po imenu, prezimenu ili emailu..." autocomplete="off" />
        </label>
    </div>

    <table class="table responsive-table" data-admin-account-requests-table>
        <thead>
            <tr>
                <th>Korisnik</th>
                <th>Email</th>
                <th>Uloga</th>
                <th>Specijalizacija</th>
                <th>Datum</th>
                <th>Status</th>
                <th class="text-end">Akcija</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var zahtjev in Model)
            {
                <tr data-account-request-row
                    data-search="@($"{zahtjev.ImePrezime} {zahtjev.Email} {zahtjev.Uloga} {zahtjev.Specijalizacija} {zahtjev.Status}")">
                    <td><strong>@zahtjev.ImePrezime</strong></td>
                    <td>@zahtjev.Email</td>
                    <td>@zahtjev.Uloga</td>
                    <td>@zahtjev.Specijalizacija</td>
                    <td>@(zahtjev.Datum.HasValue ? zahtjev.Datum.Value.ToString("dd.MM.yyyy HH:mm") : "-")</td>
                    <td><span class="status-badge status-@zahtjev.Status.ToLower()">@zahtjev.Status</span></td>
                    <td>
                        <div class="actions">
                            @if (zahtjev.MozePregled)
                            {
                                <a class="btn btn-outline-secondary btn-sm"
                                   asp-action="ZahtjevNalogaDetalji"
                                   asp-route-id="@zahtjev.Id">Pregled</a>
                            }
                            else
                            {
                                <span class="muted-text">-</span>
                            }
                        </div>
                    </td>
                </tr>
            }
            <tr id="accountRequestsEmptyRow" hidden>
                <td colspan="7" class="text-center text-muted py-4">Nema naloga za odabranu pretragu.</td>
            </tr>
        </tbody>
    </table>

    <div class="admin-patient-footer" aria-label="Paginacija naloga">
        <div class="admin-patient-page-size">
            <span>Prikazi</span>
            <select id="accountRequestPageSize" aria-label="Broj naloga po stranici">
                <option value="10" selected>10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
            <span>od <span id="accountRequestResultCount">@Model.Count</span> rezultata</span>
        </div>

        <div class="admin-patient-pagination">
            <button type="button" data-account-request-page="first" aria-label="Prva stranica">&laquo;</button>
            <button type="button" data-account-request-page="prev" aria-label="Prethodna stranica">&lsaquo;</button>
            <span id="accountRequestCurrentPage">1</span>
            <button type="button" data-account-request-page="next" aria-label="Sljedeca stranica">&rsaquo;</button>
            <button type="button" data-account-request-page="last" aria-label="Zadnja stranica">&raquo;</button>
        </div>
    </div>
</section>
