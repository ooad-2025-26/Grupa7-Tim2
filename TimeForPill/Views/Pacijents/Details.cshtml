@model Pacijent

@{
    ViewData["Title"] = "Detalji pacijenta";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Korisnici</p>
        <h1>@Model.Ime @Model.Prezime</h1>
    </div>
    <div class="actions">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Uredi</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Nazad</a>
    </div>
</div>

<div class="details-shell">
    <dl class="row mb-0">
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Datum rodjenja</dt>
        <dd class="col-sm-9">@Model.DatumRodjenja.ToString("dd.MM.yyyy")</dd>
        <dt class="col-sm-3">Spol</dt>
        <dd class="col-sm-9">@Model.Spol</dd>
        <dt class="col-sm-3">Ljekar</dt>
        <dd class="col-sm-9">@(Model.Ljekar == null ? "Nije dodijeljen" : Model.Ljekar.Ime + " " + Model.Ljekar.Prezime)</dd>
        <dt class="col-sm-3">Kontakt osoba</dt>
        <dd class="col-sm-9">@(Model.KontaktOsoba == null ? "Nema kontakta" : Model.KontaktOsoba.Ime + " " + Model.KontaktOsoba.Prezime)</dd>
        <dt class="col-sm-3">Kontakt email</dt>
        <dd class="col-sm-9">@(Model.KontaktOsoba == null ? "-" : Model.KontaktOsoba.Email)</dd>
        <dt class="col-sm-3">Kontakt telefon</dt>
        <dd class="col-sm-9">@(Model.KontaktOsoba == null ? "-" : Model.KontaktOsoba.BrojTelefona)</dd>
    </dl>
</div>
