@model IEnumerable<Zahtjev>

@{
    ViewData["Title"] = "Zahtjevi";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Obrada</p>
        <h1>Zahtjevi</h1>
    </div>
    <a class="btn btn-primary" asp-action="Create">Dodaj zahtjev</a>
</div>

<div class="table-shell table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Naziv</th>
                <th>Status</th>
                <th>Terapija</th>
                <th>Sadrzaj</th>
                <th class="text-end">Akcije</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Naziv</strong></td>
                <td>@item.Status</td>
                <td>@(item.Terapija?.Naziv ?? "Nije odabrana")</td>
                <td>@item.Sadrzaj</td>
                <td>
                    <div class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Uredi</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Detalji</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Obrisi</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
