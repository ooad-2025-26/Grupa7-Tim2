@model IEnumerable<Administrator>

@{
    ViewData["Title"] = "Administratori";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Korisnici</p>
        <h1>Administratori</h1>
    </div>
    <a class="btn btn-primary" asp-action="Create">Dodaj administratora</a>
</div>

<div class="table-shell table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Administrator</th>
                <th>Email</th>
                <th>Datum imenovanja</th>
                <th>Spol</th>
                <th class="text-end">Akcije</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Ime @item.Prezime</strong></td>
                <td>@item.Email</td>
                <td>@item.datumImenovanja.ToString("dd.MM.yyyy")</td>
                <td>@item.Spol</td>
                <td>
                    <div class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Uredi</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Detalji</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Obrisi</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
