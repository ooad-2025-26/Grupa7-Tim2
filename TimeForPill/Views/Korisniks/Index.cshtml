@model IEnumerable<Korisnik>

@{
    ViewData["Title"] = "Korisnici";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Pregled</p>
        <h1>Korisnici</h1>
    </div>
    <div class="actions">
        <a class="btn btn-primary" asp-controller="Pacijents" asp-action="Create">Dodaj pacijenta</a>
        <a class="btn btn-outline-secondary" asp-controller="Ljekars" asp-action="Create">Dodaj ljekara</a>
    </div>
</div>

<div class="table-shell table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Korisnik</th>
                <th>Email</th>
                <th>Tip</th>
                <th>Spol</th>
                <th>Datum rodjenja</th>
                <th class="text-end">Akcije</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Ime @item.Prezime</strong></td>
                <td>@item.Email</td>
                <td>@item.GetType().Name</td>
                <td>@item.Spol</td>
                <td>@item.DatumRodjenja.ToString("dd.MM.yyyy")</td>
                <td>
                    <div class="actions">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Uredi</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Detalji</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Obrisi</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
